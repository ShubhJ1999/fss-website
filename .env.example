# Vite-exposed (client-side). Empty disables analytics.
VITE_PLAUSIBLE_DOMAIN=fermionsoftwaresolutions.com

# Pages Function secrets — for local dev these live in .dev.vars (gitignored),
# for production they go in Cloudflare Pages → Settings → Environment variables.
# CONTACT_TO_EMAIL accepts a single address or comma-separated list.
RESEND_API_KEY=re_xxx
CONTACT_TO_EMAIL=you@gmail.com,partner@gmail.com
